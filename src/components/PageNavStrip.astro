---
/**
 * Horizontal strip of icon + label links for "On this page" style nav.
 * Pass <li> items as slot content; each <li> should contain an <a> and optional icon.
 */
---
<nav class="page-nav-strip" aria-label="On this page">
	<ul class="page-nav-strip__list">
		<slot />
	</ul>
</nav>

<style>
	.page-nav-strip {
		margin: 1rem 0 1.5rem;
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}
	.page-nav-strip__list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.page-nav-strip__list :global(li) {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}
	.page-nav-strip__list :global(a) {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		text-decoration: none;
		border-radius: 0.25rem;
		padding: 0.25rem 0.5rem;
		transition: color 0.15s ease, background 0.15s ease;
	}
	.page-nav-strip__list :global(a:hover) {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}
	.page-nav-strip__list :global(a svg) {
		width: 1rem;
		height: 1rem;
		opacity: 0.85;
	}
	/* Brand colors for Simple Icons in the nav strip */
	.page-nav-strip__list :global(li.nav-icon-aws a svg) {
		color: #ff9900;
	}
	.page-nav-strip__list :global(li.nav-icon-iam a svg) {
		color: #14b8a6;
	}
	.page-nav-strip__list :global(li.nav-icon-terraform a svg) {
		color: #7b42bc;
	}
	.page-nav-strip__list :global(li.nav-icon-kubernetes a svg) {
		color: #326ce5;
	}
	.page-nav-strip__list :global(li.nav-icon-git a svg) {
		color: #f05032;
	}
</style>
